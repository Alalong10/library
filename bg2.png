<?php
require_once '../includes/functions.php';
require_admin_login();
require_once '../includes/dbconnection.php';

$search = sanitize_input($_GET['search'] ?? '');
$sort = sanitize_input($_GET['sort'] ?? 'name');
$order = sanitize_input($_GET['order'] ?? 'ASC');
$page = isset($_GET['page']) && is_numeric($_GET['page']) ? (int)$_GET['page'] : 1;
$limit = 10;
$offset = ($page - 1) * $limit;

// Validate sort and order parameters
$allowed_sorts = ['name', 'student_id', 'course', 'username'];
$allowed_orders = ['ASC', 'DESC'];

if (!in_array($sort, $allowed_sorts)) {
    $sort = 'name';
}
if (!in_array($order, $allowed_orders)) {
    $order = 'ASC';
}

// Prepare search condition
$search_sql = "";
if (!empty($search)) {
    $search_param = "%$search%";
    $stmt_total = $conn->prepare("SELECT COUNT(*) FROM students WHERE name LIKE ? OR username LIKE ?");
    $stmt_total->bind_param("ss", $search_param, $search_param);
    $stmt_total->execute();
    $stmt_total->bind_result($total_students);
    $stmt_total->fetch();
    $stmt_total->close();

    $stmt = $conn->prepare("SELECT id, student_id, name, course, username FROM students WHERE name LIKE ? OR username LIKE ? ORDER BY $sort $order LIMIT ? OFFSET ?");
    $stmt->bind_param("ssii", $search_param, $search_param, $limit, $offset);
} else {
    $result_total = $conn->query("SELECT COUNT(*) AS total FROM students");
    $row_total = $result_total->fetch_assoc();
    $total_students = $row_total['total'] ?? 0;

    $stmt = $conn->prepare("SELECT id, student_id, name, course, username FROM students ORDER BY $sort $order LIMIT ? OFFSET ?");
    $stmt->bind_param("ii", $limit, $offset);
}

$stmt->execute();
$result = $stmt->get_result();

$total_pages = ceil($total_students / $limit);
?>
