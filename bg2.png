                    <th><a href="?page=1&search=<?php echo urlencode($search); ?>&sort=course&order=<?php echo ($sort == 'course' && $order == 'ASC') ? 'DESC' : 'ASC'; ?>" class="sort-link">Course<?php if ($sort == 'course') echo '<i class="fas fa-sort-' . ($order == 'ASC' ? 'up' : 'down') . '"></i>'; else echo '<i class="fas fa-sort"></i>'; ?></a></th>
